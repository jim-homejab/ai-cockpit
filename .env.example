# Chief — environment variables.
# Copy to .env.local and fill in. NEVER commit real values; .env* is gitignored.

# --- Supabase (Phase 1) ---
# Project settings → API. The anon key is safe for the browser; RLS enforces access.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Anthropic (REQUIRED — Chief runs on it; also powers KB classify-on-save
#     and merge). Get a key at console.anthropic.com. ---
ANTHROPIC_API_KEY=
# Optional override; defaults to the chief.model setting (claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Voyage embeddings (optional — semantic KB search; without it the KB
#     degrades gracefully to full-text search) ---
# VOYAGE_API_KEY=
